APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///./data/ollama_file_organizer.db
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=120
DRY_RUN=true
AUTO_PROCESSING=false
AUTO_CONFIDENCE_THRESHOLD=0.95
REVIEW_CONFIDENCE_THRESHOLD=0.80
MAX_FILE_SIZE_MB=100
MAX_EXTRACTED_TEXT_LENGTH=30000
SCAN_BATCH_SIZE=200
ALLOWED_EXTENSIONS=.txt,.md,.csv,.json,.pdf,.docx,.xlsx
DEFAULT_EXCLUDE_PATTERNS=~$*,*.tmp,*.temp,*.part,*.crdownload,*.download,.DS_Store,Thumbs.db,desktop.ini
MATTERMOST_ENABLED=false
MATTERMOST_WEBHOOK_URL=
LOG_LEVEL=INFO
